# Copy to .env.local and fill in. Without GEMINI_API_KEY the chat stays in its
# calm offline state (it points visitors to the contact email) instead of erroring.

# Google Gemini - get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash
# Optional. Caps the model's reply length to keep responses short and cheap.
CHAT_MAX_OUTPUT_TOKENS=400

# Per-IP rate limits for the chat. Defaults are 8/minute and 40/day.
CHAT_RATE_PER_MINUTE=8
CHAT_RATE_PER_DAY=40

# Upstash Redis (REST) - powers rate limiting across serverless invocations in
# production. Without these the limiter falls back to per-process memory, which
# is fine for local dev. Create a database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
